<div class="import-dialog-content">
    <div class="form-group">
        <label for="obsidian-vault-path">{{localize "obsidian-bridge.import.vault-path-label"}}</label>
        <div class="form-fields">
            <input type="text" id="obsidian-vault-path" class="vault-path" name="vaultPath" value="{{vaultPath}}"
                   readonly placeholder="No vault selected" />
            <button type="button" data-action="selectVault" class="select-folder-button">
                <i class="fas fa-folder-open"></i> {{localize "obsidian-bridge.import.select-vault-button"}}
            </button>
        </div>
        <input type="file" class="vault-input" webkitdirectory directory multiple />
        <p class="hint">{{localize "obsidian-bridge.import.vault-path-hint"}}</p>
    </div>

    {{#if vaultFileTree}}
    <div class="form-group file-tree-group">
        <label>{{localize "obsidian-bridge.import.file-selection-label"}}</label>
        <div class="file-tree" data-tree-root="true">
            <div id="vault-file-tree"></div>
        </div>
        <p class="hint">{{localize "obsidian-bridge.import.file-selection-hint"}}</p>
    </div>

    <div class="form-group destination-folder">
        <label for="obsidian-destination-folder">{{localize "obsidian-bridge.import.destination-folder-label"}}</label>
        <div class="form-fields">
            <select id="obsidian-destination-folder" name="destinationFolder">
                <option value="">{{localize "obsidian-bridge.import.destination-folder-none"}}</option>
                {{#each journalFolders}}
                <option value="{{this.id}}" {{#if (eq this.id ../destinationFolder)}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
            </select>
        </div>
    </div>

    <div class="form-group">
        <label>
            <input type="checkbox" name="combineNotes" {{checked combineNotes}} {{#if splitByHeadings}}disabled{{/if}} data-toggle-visibility="skipFolderCombine" />
            {{localize "obsidian-bridge.import.combine-notes-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.combine-notes-hint"}}</p>
    </div>

    {{#if combineNotes}}
    <div class="form-group" data-visibility-target="skipFolderCombine">
        <label>
            <input type="checkbox" name="skipFolderCombine" {{checked skipFolderCombine}} />
            {{localize "obsidian-bridge.import.skip-folder-combine-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.skip-folder-combine-hint"}}</p>
    </div>
    {{/if}}

    <div class="form-group">
        <label>
            <input type="checkbox" name="splitByHeadings" {{checked splitByHeadings}} {{#if combineNotes}}disabled{{/if}} data-toggle-visibility="splitHeadingLevel" />
            {{localize "obsidian-bridge.import.split-by-headings-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.split-by-headings-hint"}}</p>
    </div>

    {{#if splitByHeadings}}
    <div class="form-group" data-visibility-target="splitHeadingLevel">
        <label for="obsidian-split-heading-level">{{localize "obsidian-bridge.import.split-heading-level-label"}}</label>
        <select id="obsidian-split-heading-level" name="splitHeadingLevel" data-default="{{splitHeadingLevel}}">
            <option value="1">H1</option>
            <option value="2">H2</option>
            <option value="3">H3</option>
            <option value="4">H4</option>
            <option value="5">H5</option>
            <option value="6">H6</option>
        </select>
        <p class="hint">{{localize "obsidian-bridge.import.split-heading-level-hint"}}</p>
    </div>
    {{/if}}

    <div class="form-group">
        <label>
            <input type="checkbox" name="strictLineBreaks" {{checked strictLineBreaks}} />
            {{localize "obsidian-bridge.import.strict-line-breaks-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.strict-line-breaks-hint"}}</p>
    </div>

    <div class="form-group">
        <label>
            <input type="checkbox" name="importAssets" {{checked importAssets}} data-toggle-visibility="dataPath" />
            {{localize "obsidian-bridge.import.import-assets-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.import-assets-hint"}}</p>
    </div>

    {{#if importAssets}}
    <div class="form-group" data-visibility-target="dataPath">
        <label for="obsidian-data-path">{{localize "obsidian-bridge.import.data-path-label"}}</label>
        <input type="text" id="obsidian-data-path" name="dataPath" value="{{dataPath}}"
               placeholder="worlds/my-world/obsidian-assets" />
        <p class="hint">{{localize "obsidian-bridge.import.data-path-hint"}}</p>
    </div>
    {{/if}}

    {{#if showStatblockOption}}
    <div class="form-group statblock-options">
        <label>
            <input type="checkbox" name="importStatblocks" {{checked importStatblocks}} />
            {{localize "obsidian-bridge.import.statblock-label"}}
        </label>
        <p class="hint">{{localize "obsidian-bridge.import.statblock-hint"}}</p>
    </div>

    {{#if importStatblocks}}
    <div class="form-group statblock-folder">
        <label for="obsidian-statblock-folder">{{localize "obsidian-bridge.import.statblock-folder-label"}}</label>
        <div class="form-fields">
            <select id="obsidian-statblock-folder" name="statblockFolder">
                <option value="">{{localize "obsidian-bridge.import.statblock-folder-none"}}</option>
                {{#each actorFolders}}
                <option value="{{this.id}}" {{#if (eq this.id ../statblockFolder)}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
            </select>
        </div>
    </div>
    {{/if}}
    {{/if}}
    {{/if}}

    <footer class="form-footer flexrow">
        <button type="submit" class="primary">
            <i class="fas fa-file-import"></i> {{localize "obsidian-bridge.import.import-button"}}
        </button>
        <button type="button" data-action="close">
            <i class="fas fa-times"></i> {{localize "obsidian-bridge.import.cancel-button"}}
        </button>
    </footer>
</div>
